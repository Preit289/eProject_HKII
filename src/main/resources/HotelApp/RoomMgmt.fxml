<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="HotelApp.RoomMgmtController" prefWidth="980" prefHeight="640" styleClass="panel">

    <!-- Header + cards -->
    <top>
        <VBox spacing="12">
            <HBox spacing="8" styleClass="panelHeader" alignment="CENTER_LEFT">
                <Label text="Room Management" styleClass="panelTitle"/>
                <Pane HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblDate" text="24th August 2025" styleClass="panelDate"/>
                <Label text="Lee | Manager" styleClass="panelDate" style="-fx-padding:0 0 0 16;"/>
            </HBox>

            <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-padding:0 16;">
                <VBox spacing="4" styleClass="card">
                    <Label text="Booking (today)" styleClass="cardTitle"/>
                    <Label fx:id="lblBookingToday" styleClass="cardValue" text="0"/>
                </VBox>
                <VBox spacing="4" styleClass="card">
                    <Label text="Check-in (today)" styleClass="cardTitle"/>
                    <Label fx:id="lblCheckinToday" styleClass="cardValue" text="0"/>
                </VBox>
                <VBox spacing="4" styleClass="card">
                    <Label text="Check-out (today)" styleClass="cardTitle"/>
                    <Label fx:id="lblCheckoutToday" styleClass="cardValue" text="0"/>
                </VBox>
                <VBox spacing="4" styleClass="card">
                    <Label text="Available (today)" styleClass="cardTitle"/>
                    <Label fx:id="lblAvailableToday" styleClass="cardValue" text="0"/>
                </VBox>
            </HBox>
        </VBox>
    </top>

    <!-- Content -->
    <center>
        <GridPane hgap="12" vgap="12" style="-fx-padding:16;">
            <columnConstraints>
                <ColumnConstraints percentWidth="65"/>
                <ColumnConstraints percentWidth="35"/>
            </columnConstraints>

            <!-- Table + search -->
            <VBox spacing="10" GridPane.columnIndex="0">
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="Search"/>
                    <TextField fx:id="txtSearch" promptText="Room or customer name or phone number" HBox.hgrow="ALWAYS"/>
                    <Button text="Filter" onAction="#onFilter" styleClass="button,primary"/>
                    <Button text="Search" onAction="#onSearch" styleClass="button,ghost"/>
                </HBox>

                <TableView fx:id="tbl" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colRoom"   text="Room"       prefWidth="100"/>
                        <TableColumn fx:id="colType"   text="Type"       prefWidth="130"/>
                        <TableColumn fx:id="colAvail"  text="Availability" prefWidth="120"/>
                        <TableColumn fx:id="colRate"   text="Rate"       prefWidth="120"/>
                        <TableColumn fx:id="colIn"     text="Check-in"   prefWidth="130"/>
                        <TableColumn fx:id="colOut"    text="Check-out"  prefWidth="130"/>
                        <TableColumn fx:id="colAction" text="Action"     prefWidth="100"/>
                    </columns>
                </TableView>
            </VBox>

            <!-- Form chi tiết -->
            <VBox spacing="10" GridPane.columnIndex="1" styleClass="panel">
                <Label text="Room detail" style="-fx-font-weight:bold; -fx-font-size:14;"/>
                <GridPane hgap="10" vgap="10">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="30"/>
                        <ColumnConstraints percentWidth="70"/>
                    </columnConstraints>

                    <Label text="Room" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtRoom" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                    <Label text="Rate" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtRate" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                    <Label text="Status" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <ChoiceBox fx:id="cbStatus" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                    <Label text="Type" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                    <ChoiceBox fx:id="cbType" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                    <Label text="Facilities" GridPane.rowIndex="4" GridPane.columnIndex="0" GridPane.valignment="TOP"/>
                    <TextArea fx:id="txFacilities" prefRowCount="4" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                </GridPane>

                <HBox spacing="8" alignment="CENTER_RIGHT">
                    <Button text="Reset" onAction="#onReset"/>
                    <Button text="Process" onAction="#onProcess" styleClass="button,primary"/>
                </HBox>
            </VBox>
        </GridPane>
    </center>
</BorderPane>
